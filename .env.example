# Required: your Anthropic API key (https://console.anthropic.com/)
ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: model to use (default: claude-sonnet-5)
CLAUDE_MODEL=claude-sonnet-5

# Optional: system prompt / persona for the bot
SYSTEM_PROMPT=You are a helpful, concise assistant.

# Optional: max tokens per reply (default: 1024)
MAX_TOKENS=1024

# Optional: shared-secret token to protect /chat and /reset.
# If set, callers must send: Authorization: Bearer <API_AUTH_TOKEN>
API_AUTH_TOKEN=

# Optional: Railway sets PORT automatically — no need to set this yourself
PORT=3000
